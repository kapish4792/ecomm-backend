<!DOCTYPE html
    PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>Password Reset | ATELIER</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style type="text/css">
        /* Basic Reset */
        body,
        table,
        td,
        a {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table,
        td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        img {
            -ms-interpolation-mode: bicubic;
            border: 0;
            height: auto;
            line-height: 100%;
            outline: none;
            text-decoration: none;
        }

        table {
            border-collapse: collapse !important;
        }

        body {
            height: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            background-color: #fbf9f9;
        }

        /* Web Font Load */
        @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:wght@600&family=Hanken+Grotesk:wght@400;700&display=swap');

        /* Hover Effects (Works in some clients) */
        .cta-button:hover {
            background-color: #735c00 !important;
            /* Your primary gold color */
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #fbf9f9; font-family: 'Hanken Grotesk', Helvetica, Arial, sans-serif;">
    <table border="0" cellpadding="0" cellspacing="0" width="100%">
        <tr>
            <td align="center" style="padding: 40px 0; border-bottom: 1px solid #e2dfde;">
                <h1
                    style="margin: 0; font-family: 'Bodoni Moda', serif; font-size: 28px; letter-spacing: 0.4em; color: #1b1c1c; text-transform: uppercase;">
                    ATELIER</h1>
            </td>
        </tr>

        <tr>
            <td align="center" style="padding: 60px 20px;">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px;">

                    <tr>
                        <td align="center" style="padding-bottom: 48px;">
                            <div style="background-color: #efeded; width: 100%;">
                                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuB_-HZAwN0oCryzNhUZursA2S1bSYRDtfO9IHhfN5oY70PXKlikqdm7tl3kIaQt8uiZZxdER4PRfd54c1Zl3kdBFh2XmBkNh9bTZTkiCiRJNptbV9a0gnnXFeYy7LQEyIIZgeohaLr51dzTWDTppr3MQYd9ura0xyt0W5pfI7Kc6oNhUW1lksYrxsUItkFJAysutv3LldI5S1hftqt7TYnU4S5SsXOLj0oyYOdCbcXD4P8bAK-hJZcrRulk0i22ACGUoISQE648qKk"
                                    alt="Atelier Gallery" width="600"
                                    style="display: block; width: 100%; filter: grayscale(100%); opacity: 0.9;" />
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td align="center" style="padding-bottom: 16px;">
                            <h2
                                style="margin: 0; font-family: 'Bodoni Moda', serif; font-size: 32px; font-weight: 600; color: #1b1c1c;">
                                Hello, <%= name ? name : 'Guest' %>
                            </h2>
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="padding-bottom: 24px;">
                            <p
                                style="margin: 0; font-family: 'Bodoni Moda', serif; font-size: 20px; color: #1b1c1c; letter-spacing: 0.05em; text-transform: uppercase;">
                                Password Reset Request</p>
                        </td>
                    </tr>

                    <tr>
                        <td align="center" style="padding-bottom: 40px;">
                            <p style="margin: 0; font-size: 17px; line-height: 28px; color: #5f5e5e; max-width: 460px;">
                                We received a request to reset your password for your Atelier account. If this was you,
                                please use the button below to secure your account.
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td align="center" style="padding-bottom: 60px;">
                            <a href="<%= resetUrl %>" class="cta-button"
                                style="background-color: #1b1c1c; color: #fbf9f9; padding: 20px 48px; text-decoration: none; font-size: 12px; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; display: inline-block; transition: all 0.3s ease;">
                                RESET PASSWORD
                            </a>
                        </td>
                    </tr>

                    <tr>
                        <td align="center" style="padding-bottom: 40px;">
                            <div style="width: 64px; height: 1px; background-color: #d0c5af;"></div>
                        </td>
                    </tr>

                    <tr>
                        <td align="center" style="padding-bottom: 80px;">
                            <p
                                style="margin: 0; font-size: 14px; font-style: italic; color: #474744; opacity: 0.7; max-width: 380px; line-height: 22px;">
                                If you did not request this change, you can safely ignore this email. This link is valid
                                for a limited time.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        <tr>
            <td align="center" style="padding: 80px 20px; background-color: #fbf9f9; border-top: 1px solid #e2dfde;">
                <table border="0" cellpadding="0" cellspacing="0" width="100%"
                    style="max-width: 600px; text-align: center;">
                    <tr>
                        <td style="padding-bottom: 24px;">
                            <p
                                style="margin: 0; font-size: 12px; font-weight: 700; letter-spacing: 0.2em; color: #1b1c1c; text-transform: uppercase;">
                                ATELIER ARCHITECTURAL</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-bottom: 32px;">
                            <a href="#"
                                style="color: #5f5e5e; text-decoration: none; font-size: 11px; padding: 0 15px; text-transform: uppercase; letter-spacing: 0.1em;">Support</a>
                            <a href="#"
                                style="color: #5f5e5e; text-decoration: none; font-size: 11px; padding: 0 15px; text-transform: uppercase; letter-spacing: 0.1em;">Privacy
                                Policy</a>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <p
                                style="margin: 0; font-size: 11px; color: #5f5e5e; opacity: 0.5; letter-spacing: 0.05em;">
                                © 2026 ATELIER ARCHITECTURAL. ALL RIGHTS RESERVED.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>

</html>