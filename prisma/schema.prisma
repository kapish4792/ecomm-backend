generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. AUTHENTICATION & ROLE MANAGEMENT
// ==========================================

model Role {
  id          Int      @id @default(autoincrement())
  name        UserRole @unique @default(USER)
  description String?  @db.VarChar(255)
  users       users[]

  @@map("roles")
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

model refresh_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  token      String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                     Int       @id @default(autoincrement())
  name                   String    @db.VarChar(100)
  email                  String    @unique @db.VarChar(100)
  password               String    @db.VarChar(255)
  phone                  String    @unique @db.VarChar(15)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  reset_password_token   String?   @db.Text
  reset_password_expires DateTime? @db.Timestamp(6)

  role_id Int  @default(1)
  role    Role @relation(fields: [role_id], references: [id])

  refresh_tokens refresh_tokens[]
  orders         Order[]
  transactions   Transaction[]
}

// ==========================================
// 2. PRODUCT CATALOG (WITH VARIANTS)
// ==========================================

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  price           Decimal          @db.Decimal(12, 2)
  category        String
  displayCategory String?
  imageUrl        String
  images          String[]         @default([])
  description     String           @db.Text
  attributes      Attribute[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isDeleted       Boolean          @default(false)
  variants        ProductVariant[]

  @@index([category])
}

model ProductVariant {
  id         String      @id @default(uuid())
  sku        String      @unique
  size       String?
  color      String?
  stock      Int         @default(0)
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[] // Relation link to purchased line items
}

model Attribute {
  id       String    @id @default(uuid())
  key      String
  value    String
  products Product[]

  @@unique([key, value])
}

// ==========================================
// 3. ORDERS & SUBSYSTEM LAYERS
// ==========================================

model Order {
  id              String      @id @default(uuid())
  userId          Int
  user            users       @relation(fields: [userId], references: [id])
  totalAmount     Decimal     @db.Decimal(12, 2) // Calculated subtotal + taxes + shipping
  shippingAddress Json // Immutable JSON snapshot of address block details at point of purchase
  status          OrderStatus @default(PENDING)
  idempotencyKey  String?     @unique // Structural safeguard tracking unique frontend checkout generation keys
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items        OrderItem[]
  transactions Transaction[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAYMENT_FAILED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  priceAtPurchase  Decimal        @db.Decimal(12, 2) // CRITICAL: Immutable snapshot of the unit price at transaction execution time

  @@map("order_items")
}

// ==========================================
// 4. TRANSACTION & AUDIT TRACKING
// ==========================================

model Transaction {
  id                   String            @id @default(uuid())
  orderId              String
  order                Order             @relation(fields: [orderId], references: [id])
  userId               Int
  user                 users             @relation(fields: [userId], references: [id])
  gatewayTransactionId String            @unique // Unique payment reference identifier string returned from gateway providers (e.g. Stripe, Razorpay)
  amount               Decimal           @db.Decimal(12, 2)
  currency             String            @default("INR") @db.VarChar(10)
  gateway              PaymentGateway
  status               TransactionStatus
  rawGatewayResponse   Json? // Stores the raw webhook receipt callback schema dictionary details for debugging audits
  createdAt            DateTime          @default(now())

  @@map("transactions")
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
  PAYPAL
  COD
}

enum TransactionStatus {
  SUCCESS
  FAILED
  REFUNDED
}

// ==========================================
// 5. CACHED IDEMPOTENCY ENGINE LOGS
// ==========================================

model IdempotencyRecord {
  id             String            @id @default(uuid())
  key            String            @unique // Unique Client generated token UUID string passed down via headers
  requestPath    String // Verify matching routing execution path (e.g., "/api/checkout")
  status         IdempotencyStatus @default(PROCESSING)
  responseBody   Json? // Cached return object body tracking processed orders
  responseStatus Int? // Cached response status codes
  createdAt      DateTime          @default(now())
  expiresAt      DateTime // Self cleaning trigger tracking limits (e.g., 24 hours lifecycle)

  @@map("idempotency_records")
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
}
