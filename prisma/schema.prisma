generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. AUTHENTICATION & ROLE MANAGEMENT
// ==========================================

model Role {
  id          Int      @id @default(autoincrement())
  name        UserRole @unique @default(USER)
  description String?  @db.VarChar(255)
  users       users[]

  @@map("roles")
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

model refresh_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  token      String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                     Int       @id @default(autoincrement())
  name                   String    @db.VarChar(100)
  email                  String    @unique @db.VarChar(100)
  password               String    @db.VarChar(255)
  phone                  String    @unique @db.VarChar(15)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  reset_password_token   String?   @db.Text
  reset_password_expires DateTime? @db.Timestamp(6)

  role_id Int  @default(1)
  role    Role @relation(fields: [role_id], references: [id])

  refresh_tokens refresh_tokens[]
  orders         Order[]
  transactions   Transaction[]
  mediaFiles     MediaFile[]
}

// ==========================================
// 2. PRODUCT CATALOG — EAV HYBRID MODEL
// ==========================================

enum ProductStatus {
  DRAFT // Hidden from public listings
  PUBLISHED // Visible to all
  ARCHIVED // Archived product
}

model Product {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  basePrice        Decimal          @db.Decimal(12, 2) // Display / listing price
  category         String
  displayCategory  String?
  imageUrl         String           @default("")
  images           String[]         @default([])
  description      String           @db.Text
  status           ProductStatus    @default(DRAFT) // DRAFT = hidden, PUBLISHED = visible
  isDeleted        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  variants         ProductVariant[]
  categories       Category[]

  @@index([category])
  @@index([status])
  @@map("products")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(120) // URL-safe identifier
  description String?   @db.Text
  imageUrl    String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([slug]) // fast slug-based lookups
  @@index([isActive]) // fast active/inactive filtering
  @@map("categories")
}

model Attribute {
  id     String           @id @default(dbgenerated("concat('attr_', floor(random() * 90000 + 10000)::text)"))
  name   String           @unique @db.VarChar(50)
  values AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String                  @id @default(dbgenerated("concat('val_', floor(random() * 90000 + 10000)::text)"))
  attributeId String
  attribute   Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String                  @db.VarChar(100)
  variants    VariantAttributeValue[]

  @@unique([attributeId, value])
  @@map("attribute_values")
}

// The actual sellable item — each SKU is a unique combination of attribute values
model ProductVariant {
  id         String                  @id @default(dbgenerated("concat('var_', floor(random() * 90000 + 10000)::text)"))
  productId  String
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String                  @unique
  price      Decimal                 @db.Decimal(12, 2)
  stock      Int                     @default(0)
  images     String[]                @default([])
  createdAt  DateTime                @default(now())
  attributes VariantAttributeValue[]
  orderItems OrderItem[]

  @@map("product_variants")
}

// Junction table — binds variants to their specific attribute value combinations
model VariantAttributeValue {
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValueId String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@map("variant_attribute_values")
}

// ==========================================
// 3. ORDERS & SUBSYSTEM LAYERS
// ==========================================

model Order {
  id              String      @id @default(uuid())
  userId          Int
  user            users       @relation(fields: [userId], references: [id])
  totalAmount     Decimal     @db.Decimal(12, 2) // Calculated subtotal + taxes + shipping
  shippingAddress Json // Immutable JSON snapshot of address block details at point of purchase
  status          OrderStatus @default(PENDING)
  expiresAt       DateTime? // Auto-expiry timestamp for PENDING orders (15 min from creation)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items        OrderItem[]
  transactions Transaction[]
  events       OrderEvent[] // Full audit trail of state transitions

  @@map("orders")
}

// ==========================================
// Order State Machine
// PENDING → CONFIRMED, CANCELLED, FAILED
// CONFIRMED → PROCESSING, CANCELLED
// PROCESSING → SHIPPED, CANCELLED
// SHIPPED → DELIVERED, RETURNED
// DELIVERED → RETURNED
// CANCELLED, FAILED, RETURNED → terminal
// ==========================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  RETURNED
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  priceAtPurchase  Decimal        @db.Decimal(12, 2) // CRITICAL: Immutable snapshot of the unit price at transaction execution time

  @@map("order_items")
}

// ==========================================
// 3b. ORDER AUDIT EVENT LOG
// ==========================================

model OrderEvent {
  id         String       @id @default(uuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus? // null for initial PENDING creation
  toStatus   OrderStatus
  reason     String?      @db.Text // Optional human-readable reason for the transition
  actor      String?      @db.VarChar(100) // "system", "user:{id}", "webhook", "cron"
  createdAt  DateTime     @default(now())

  @@map("order_events")
}

// ==========================================
// 3c. OUTBOX PATTERN — ASYNC EVENT QUEUE
// ==========================================

model OutboxEvent {
  id          String   @id @default(uuid())
  eventType   String   @db.VarChar(100) // e.g. "order.created", "order.expired", "stock.released"
  aggregateId String   @db.VarChar(100) // Usually the orderId
  payload     Json // Full event payload for downstream consumers
  published   Boolean  @default(false) // Marks the event as picked up by the outbox processor
  createdAt   DateTime @default(now())

  @@index([published, createdAt])
  @@map("outbox_events")
}

// ==========================================
// 4. TRANSACTION & AUDIT TRACKING
// ==========================================

model Transaction {
  id                   String            @id @default(uuid())
  orderId              String
  order                Order             @relation(fields: [orderId], references: [id])
  userId               Int
  user                 users             @relation(fields: [userId], references: [id])
  gatewayTransactionId String            @unique // Unique payment reference identifier string returned from gateway providers (e.g. Stripe, Razorpay)
  amount               Decimal           @db.Decimal(12, 2)
  currency             String            @default("INR") @db.VarChar(10)
  gateway              PaymentGateway
  status               TransactionStatus
  rawGatewayResponse   Json? // Stores the raw webhook receipt callback schema dictionary details for debugging audits
  createdAt            DateTime          @default(now())

  @@map("transactions")
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
  PAYPAL
  COD
}

enum TransactionStatus {
  SUCCESS
  FAILED
  REFUNDED
  UNKNOWN // Payment status not yet confirmed — webhook reconciles
}

// ==========================================
// 5. MEDIA / FILE UPLOADS
// ==========================================

model MediaFile {
  id           String   @id @default(uuid())
  originalName String   @db.VarChar(255)
  filename     String   @db.VarChar(255)
  fileUrl      String   @db.Text
  mimeType     String   @db.VarChar(100)
  size         Int
  uploadedBy   Int?
  user         users?   @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@map("media_files")
}
